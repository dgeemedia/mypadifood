<main class="container">
  <div class="hero">
    <h1>Find local food vendors near you 👩🍳</h1>
    <p>Order, reserve, and support verified vendors in your neighborhood.</p>

    <div class="hero-cta">
      <a class="button" href="/vendors/new">Join as a vendor (Enroll your business)</a>
    </div>
  </div>

  <section class="vendors">
    <h2>Vendors</h2>
    <div class="controls">
      <label>Show:
        <select id="filterStatus">
          <option value="all">All</option>
          <option value="verified">Verified</option>
          <option value="unverified">Unverified</option>
        </select>
      </label>
    </div>
    <div id="vendorsList" class="cards" aria-live="polite"></div>
  </section>
</main>
