<% 
  const fallbackNumber = '2348110252143';
  function toIntl(phone) {
    if (!phone) return fallbackNumber;
    let cleaned = (''+phone).replace(/\D/g, '');
    if (cleaned.startsWith('0')) cleaned = '234' + cleaned.slice(1);
    if (cleaned.length < 7) return fallbackNumber;
    return cleaned;
  }
  const waNumber = toIntl(vendor.phone || '');
  const waMessage = `Booking request: Vendor: ${vendor.name} | Location: ${vendor.address}`;
%>

<section class="vendor-profile">
  <h1><%= vendor.name %> <span class="badge"><%= vendor.status %></span></h1>
  <p><%= vendor.address %></p>
  <p>Food: <%= vendor.food_item %> — Price: ₦<%= vendor.price_min %></p>

  <div class="actions">
    <button id="orderNow">Order now</button>

    <button type="button"
      class="button-like wa-btn"
      data-wa-number="<%= waNumber %>"
      data-wa-message="<%= waMessage.replace(/\"/g, '&quot;') %>">
      Book a plate offline
    </button>
  </div>
</section>
