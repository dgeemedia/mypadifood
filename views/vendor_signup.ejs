<!-- views/vendor_signup.ejs -->
<main class="container">
  <div class="signup-wrap card">
    <header class="signup-header">
      <h2>Vendor Enrollment</h2>
      <p class="muted">Fill in the form below to enroll your business.</p>
    </header>

    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <form id="vendorForm" method="post" action="/vendors" class="form-grid" novalidate>
      <fieldset>
        <legend class="sr-only">Business details</legend>

        <label class="form-row">
          <span class="label-text">Business / Stall name <span class="required">*</span></span>
          <input name="name" id="name" required placeholder="e.g. Mama Chichi Jollof" />
        </label>

        <div class="two-col">
          <label class="form-row">
            <span class="label-text">Country</span>
            <select name="country" id="countrySelect" required>
              <option value="Nigeria" selected>Nigeria</option>
            </select>
          </label>

          <label class="form-row">
            <span class="label-text">Business Type</span>
            <input name="business_type" id="business_type" placeholder="Stall, Restaurant, Caterer" />
          </label>
        </div>

        <div class="two-col">
          <label class="form-row">
            <span class="label-text">State <span class="required">*</span></span>
            <select name="state" id="stateSelect" required>
              <option value="">Select State</option>
              <% Object.keys(states).forEach(s => { %>
                <option value="<%= s %>"><%= s %></option>
              <% }) %>
            </select>
          </label>

          <label class="form-row">
            <span class="label-text">LGA</span>
            <select name="lga" id="lgaSelect">
              <option value="">Select LGA</option>
            </select>
          </label>
        </div>

        <label class="form-row">
          <span class="label-text">Manual Address <span class="required">*</span></span>
          <input name="address" id="addressInput" required placeholder="Street, building, landmark" />
        </label>

        <div class="two-col">
          <label class="form-row">
            <span class="label-text">Food item <span class="required">*</span></span>
            <input name="food_item" id="food_item" required placeholder="e.g. Jollof Rice" />
          </label>

          <label class="form-row">
            <span class="label-text">Base price (NGN) <span class="required">*</span></span>
            <input name="price_min" id="price_min" type="number" min="100" required placeholder="e.g. 1200" />
          </label>
        </div>

        <div class="two-col">
          <label class="form-row">
            <span class="label-text">Email</span>
            <input name="email" id="email" type="email" placeholder="vendor@example.com" />
          </label>

          <label class="form-row">
            <span class="label-text">Phone</span>
            <input name="phone" id="phone" placeholder="080xxxxxxx" />
          </label>
        </div>

      </fieldset>

      <fieldset>
        <legend class="sr-only">Map & preview</legend>

        <div class="map-controls">
          <div class="map-actions">
            <button type="button" id="autoLocate" class="btn secondary">Auto-locate me</button>
            <button type="button" id="previewBtn" class="btn">Preview on map</button>
          </div>
          <div class="map-help muted">Click preview to geocode the address and confirm the marker. Use Auto-locate to detect your current position.</div>
        </div>

        <div id="mapPreview" class="map-preview" aria-live="polite" hidden>
          <div class="map-left">
            <img id="previewImg" alt="Location preview" />
            <p id="coordsText" class="muted kv"></p>
          </div>
          <div class="map-right">
            <p><strong>Selected coordinates</strong></p>
            <p id="coordsSmall" class="kv">None</p>
            <p class="muted">If the marker is incorrect, edit the address and Preview again.</p>
            <input type="hidden" name="lat" id="latInput" />
            <input type="hidden" name="lng" id="lngInput" />
          </div>
        </div>
      </fieldset>

      <div class="form-footer">
        <label class="consent">
          <input type="checkbox" id="agree" required />
          I confirm the information is correct and accept that admin may contact me. <span class="sr-only">Required</span>
        </label>

        <div class="actions-row">
          <button type="submit" id="submitBtn" class="btn" disabled>Submit for review</button>
          <a class="btn secondary" href="/">Cancel</a>
        </div>
      </div>

    </form>
  </div>
</main>

<!-- CONFIG: non-executing JSON (CSP-safe) -->
<script id="padi-config" type="application/json" hidden>
<%- JSON.stringify({ states: states, mapboxToken: mapboxToken }) %>
</script>

<!-- main.js is loaded site-wide via layouts/layout.ejs as a module:
     <script type="module" src="/js/main.js"></script>
     main.js will import and initialize the vendor signup module when present.
-->
