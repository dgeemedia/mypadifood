<main class="container">
  <h2>Vendor Enrollment</h2>
  <p>Fill in details to enroll. Your phone/email are private and only accessible by admin.</p>

  <form method="post" action="/vendors" class="card">
    <label>Business / Stall name <input name="name" required></label>
    <label>Address <input name="address" required></label>

    <label>State
      <select name="state" required>
        <% Object.keys(states).forEach(s => { %>
          <option value="<%= s %>"><%= s %></option>
        <% }) %>
      </select>
    </label>

    <label>LGA
      <input name="lga" placeholder="LGA (optional)"></input>
    </label>

    <label>Food item <input name="food_item" required></label>
    <label>Base price (NGN) <input name="price_min" type="number" required></label>
    <label>Email <input name="email" type="email" required></label>
    <label>Phone <input name="phone"></label>

    <button type="submit">Submit for review</button>
  </form>
</main>
